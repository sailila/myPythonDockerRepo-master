pipeline {
  agent any

  environment {
    registry = "528301062709.dkr.ecr.ap-south-1.amazonaws.com/myrepo"
  }

  stages {
    stage('Cloning Git') {
      steps {
        git url: 'https://github.com/sailila/myPythonDockerRepo-master.git', branch: 'main'
      }
    }

    stage('Build') {
      steps {
        echo 'Building project...'
      }
    }

    stage('Building image') {
      steps {
        script {
          dockerImage = docker.build("${registry}:latest")
        }
      }
    }

    stage('Pushing to ECR') {
      steps {
        script {
          sh 'aws ecr get-login-password --region ap-south-1 | docker login --username AWS --password-stdin 528301062709.dkr.ecr.ap-south-1.amazonaws.com'
          sh "docker push ${registry}:latest"
        }
      }
    }

    stage('Stop Previous Containers') {
      steps {
        sh 'docker ps -f name=mypythonContainer -q | xargs --no-run-if-empty docker container stop || true'
        sh 'docker container ls -a -f name=mypythonContainer -q | xargs --no-run-if-empty docker container rm || true'
      }
    }

    stage('Docker Run') {
      steps {
        script {
          sh "docker run -d -p 8096:5000 --rm --name mypythonContainer ${registry}:latest"
        }
      }
    }
  }
}
